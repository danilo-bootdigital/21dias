-- ============================================================================
-- Código 21 — Migration 0014: Reinicialização da Jornada (pré-lançamento)
-- ----------------------------------------------------------------------------
-- OBJETIVO: zerar a EXECUÇÃO da jornada (pontuação, check-ins e todo o
-- histórico de cada guerreiro) SEM apagar o guerreiro nem qualquer dado de
-- identidade, direito de acesso ou estrutura/catálogo do programa.
--
-- PRESERVA (NUNCA apaga):
--   users, guerreiro_profiles (linha), matriculas, entitlements, contratos,
--   organizations, organization_members, user_roles, app_settings, temporadas,
--   programas, turmas (linha), programa_fases, protocolo_dias,
--   protocolo_conteudos, protocolo_checkin_itens, protocolo_imagem_campos,
--   habitos_definicao, conquistas_definicao (CATÁLOGO), eventos, audit_log.
--
-- ATENÇÃO (passo manual fora deste SQL):
--   Os ARQUIVOS do bucket de Storage 'protocolos' NÃO são removidos por SQL.
--   Apagar via Supabase Storage (dashboard/CLI) após rodar esta migration.
--
-- DECISÕES APLICADAS (ajuste aqui se necessário):
--   [A] notificacoes ........ APAGAR TODAS.
--   [B] contrato_assinado_at  MANTER (assinaturas reais).
--   [C] turmas.status ....... -> 'ativa' (lançamento à meia-noite).
--       Pré-requisito: turmas.starts_at corretos (o "dia corrente" é calculado
--       a partir de starts_at; ver dia_corrente_em na 0006).
--
-- Execução: transacional (tudo-ou-nada). Triggers de scoring desabilitados
-- durante o wipe para evitar recálculos inúteis a cada delete.
-- REQUISITO: rodar como owner/service role (DISABLE TRIGGER exige privilégio).
-- ============================================================================

begin;

-- 1) Desabilitar triggers de scoring durante o wipe -------------------------
alter table checkin_habitos disable trigger trg_after_checkin_habito;
alter table checkins        disable trigger trg_after_checkin;

-- 2) Apagar execução/histórico — filhos antes dos pais (respeita FKs) -------
delete from protocolo_checkin_respostas;   -- respostas do checklist por check-in
delete from protocolo_imagem_envios;       -- fotos enviadas (linhas; arquivos: ver topo)
delete from checkin_habitos;               -- hábitos marcados por check-in
delete from checkins;                      -- check-ins do dia
delete from curtidas;                      -- curtidas do feed
delete from comentarios;                   -- comentários do feed
delete from posts;                         -- posts do feed
delete from conquistas_usuario;            -- conquistas conquistadas (NÃO o catálogo)
delete from certificados;                  -- certificados emitidos
delete from hall_entries;                  -- Hall da Fama
delete from notificacoes;                  -- [A] todas as notificações

-- 3) Zerar pontuação agregada (regenerada no 1º check-in real) --------------
--    DELETE em vez de UPDATE: a linha é recriada com zeros por recalc_pontuacao.
--    Necessário porque NÃO há trigger de DELETE em checkins (não zera sozinha)
--    e o nível é monotônico (recalcular não regride).
delete from pontuacao_agregada;

-- 4) Zerar estatísticas de carreira do guerreiro (mantém o perfil) ----------
update guerreiro_profiles set
  maior_streak        = 0,
  melhor_temporada_id = null,
  melhor_turma_id     = null,
  melhor_posicao      = null;

-- 5) Reverter matrículas concluídas para ativa (mantém contrato/joined_at) --
--    [B] contrato_assinado_at preservado.
update matriculas set status = 'ativa' where status = 'concluida';

-- 5b) [C] Status das turmas -> 'ativa' para o lançamento --------------------
update turmas set status = 'ativa'
  where status in ('encerrada','arquivada','agendada','contagem');

-- 6) Reabilitar triggers de scoring -----------------------------------------
alter table checkins        enable trigger trg_after_checkin;
alter table checkin_habitos enable trigger trg_after_checkin_habito;

-- 7) Auditoria da reinicialização (actor null = sistema) --------------------
insert into audit_log (actor_id, acao, alvo, meta)
values (null, 'jornada_reiniciada', 'global',
        jsonb_build_object('origem', 'reinicializacao_pre_lancamento',
                           'escopo', 'pontuacao+checkins+historico',
                           'preserva', 'guerreiros/identidade/estrutura'));

commit;

-- ============================================================================
-- VERIFICAÇÃO (rodar SEPARADO após o commit; esperado = 0 nas execuções)
-- ----------------------------------------------------------------------------
