# ──────────────────────────────────────────────────────────────
# Código 21 — variáveis de ambiente (copie para .env.local)
# Os valores reais entram nos blocos seguintes; aqui só os nomes.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (Bloco 2)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Usado por `npm run db:types` (geração de tipos a partir do projeto)
SUPABASE_PROJECT_ID=""

# Auth Google opcional (Bloco 5)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Webhook de checkout (Bloco 6)
CHECKOUT_PROVIDER="stub"
CHECKOUT_WEBHOOK_SECRET=""

# Cron de encerramento de turmas (Bloco Jornada / Fase 4)
# Enviado pelo Vercel Cron como header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
